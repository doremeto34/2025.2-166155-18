<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="20.0" styleClass="main-container" stylesheets="@../../../../../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nhom18.importorder.controller.bpdhqt.BpbhRequestListController">
   <children>
      <!-- Top Bar Header -->
      <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="page-header">
         <children>
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="page-title" text="Đơn Yêu Cầu Từ Bộ Phận Bán Hàng" />
                  <Label styleClass="page-subtitle" text="Xem và theo dõi các phiếu yêu cầu nhập hàng do nhân viên kinh doanh BPBH khởi tạo" />
               </children>
            </VBox>
            <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="button, button-secondary" text="🔄 Làm Mới" />
         </children>
      </HBox>

      <!-- SplitPane Layout for Master-Detail View -->
      <SplitPane dividerPositions="0.55" styleClass="split-pane-custom" VBox.vgrow="ALWAYS">
         <items>
            <!-- Left Panel: Master Request List -->
            <VBox spacing="12.0" styleClass="card-panel">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label styleClass="section-title" text="Danh Sách Phiếu Yêu Cầu" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="cbStatusFilter" prefWidth="220.0" promptText="Lọc theo trạng thái" styleClass="combo-box-filter" />
                     </children>
                  </HBox>
                  <TableView fx:id="tblRequests" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colId" maxWidth="80.0" minWidth="60.0" prefWidth="70.0" text="Mã YC" />
                        <TableColumn fx:id="colCreator" prefWidth="180.0" text="Nhân Viên Tạo" />
                        <TableColumn fx:id="colDate" prefWidth="140.0" text="Ngày Khởi Tạo" />
                        <TableColumn fx:id="colStatus" prefWidth="130.0" text="Trạng Thái" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </VBox>

            <!-- Right Panel: Detail Item List -->
            <VBox spacing="12.0" styleClass="card-panel">
               <children>
                  <Label styleClass="section-title" text="Chi Tiết Mặt Hàng Của Phiếu" />
                  <TableView fx:id="tblRequestItems" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colItemMerch" maxWidth="120.0" minWidth="90.0" prefWidth="100.0" text="Mã Hàng" />
                        <TableColumn fx:id="colItemName" prefWidth="200.0" text="Tên Mặt Hàng" />
                        <TableColumn fx:id="colItemQty" maxWidth="100.0" minWidth="70.0" prefWidth="80.0" text="Số Lượng" />
                        <TableColumn fx:id="colItemUnit" maxWidth="80.0" minWidth="60.0" prefWidth="70.0" text="Đơn Vị" />
                        <TableColumn fx:id="colItemDate" prefWidth="140.0" text="Ngày Nhận Mong Muốn" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                     <placeholder>
                        <Label text="Chọn một phiếu yêu cầu bên trái để xem chi tiết mặt hàng." style="-fx-text-fill: -text-secondary; -fx-font-style: italic;" />
                     </placeholder>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </children>
</VBox>

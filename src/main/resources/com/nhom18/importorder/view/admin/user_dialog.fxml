<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.nhom18.importorder.controller.admin.UserDialogController"
      spacing="20" style="-fx-padding: 25px; -fx-background-color: #f8fafc;" prefWidth="480.0">
    
    <!-- Title -->
    <VBox spacing="5">
        <Label fx:id="lblTitle" text="➕ THÊM TÀI KHOẢN NHÂN VIÊN" style="-fx-font-size: 18px; -fx-font-weight: bold;" styleClass="label" />
    </VBox>
    
    <Separator style="-fx-opacity: 0.2;" />
    
    <!-- Form Fields -->
    <GridPane hgap="15" vgap="15">
        <columnConstraints>
            <ColumnConstraints minWidth="150" prefWidth="160" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
        </columnConstraints>
        
        <children>
            <Label text="Tên đăng nhập: *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtUsername" promptText="Ví dụ: nam_bpbh, hung_bpdh" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="Họ và tên: *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txtFullName" promptText="Nhập họ và tên đầy đủ..." styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Vai trò hệ thống: *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <ComboBox fx:id="cbRole" prefWidth="250" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            
            <Label fx:id="lblSiteCode" text="Site liên kết: *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <ComboBox fx:id="cbSiteCode" prefWidth="250" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </children>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>
    
    <!-- Password field, only managed/visible on Create mode -->
    <VBox fx:id="boxPassword" spacing="10">
        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints minWidth="150" prefWidth="160" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
            </columnConstraints>
            <children>
                <Label text="Mật khẩu ban đầu: *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu ban đầu..." styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            </children>
         <rowConstraints>
            <RowConstraints />
         </rowConstraints>
        </GridPane>
    </VBox>
    
    <Separator style="-fx-opacity: 0.2;" />
    
    <!-- Actions -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="❌ Hủy bỏ" onAction="#handleCancel" styleClass="button-secondary" />
        <Button text="💾 Lưu tài khoản" onAction="#handleSave" styleClass="button" />
    </HBox>
    
</VBox>

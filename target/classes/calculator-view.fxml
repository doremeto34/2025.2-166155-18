<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CalculatorController">

    <padding>
        <Insets bottom="10" left="10" right="10" top="10" />
    </padding>

    <children>
        <TextField fx:id="display" editable="false" prefHeight="50" style="-fx-font-size: 18px; -fx-alignment: CENTER-RIGHT;" GridPane.columnSpan="4" />

        <GridPane hgap="5" vgap="5">
            <columnConstraints>
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints percentHeight="20.0" />
                <RowConstraints percentHeight="20.0" />
                <RowConstraints percentHeight="20.0" />
                <RowConstraints percentHeight="20.0" />
                <RowConstraints percentHeight="20.0" />
            </rowConstraints>

            <children>
                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="2" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="." GridPane.columnIndex="2" GridPane.rowIndex="4" />
                <Button onAction="#onOperator" prefHeight="40" prefWidth="40.0" text="/" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="7" GridPane.rowIndex="1" />
                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="8" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="9" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <Button onAction="#onOperator" prefHeight="40" prefWidth="40.0" text="*" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="4" GridPane.rowIndex="2" />
                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="5" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="6" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <Button onAction="#onOperator" prefHeight="40" prefWidth="40.0" text="-" GridPane.columnIndex="3" GridPane.rowIndex="2" />
      
                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="1" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Button onAction="#onClear" prefHeight="40" prefWidth="40.0" text="AC" />
                <Button onAction="#onBackspace" prefHeight="40" prefWidth="40.0" text="←" GridPane.rowIndex="4" />
                <Button onAction="#onOperator" prefHeight="40" prefWidth="40.0" text="+" GridPane.columnIndex="3" GridPane.rowIndex="3" />
                <Button onAction="#onRightParen" prefHeight="40" prefWidth="40.0" text=")" GridPane.columnIndex="2" />
                <Button onAction="#onEquals" prefHeight="40" prefWidth="40.0" text="=" GridPane.columnIndex="3" GridPane.rowIndex="4" />
                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <Button onAction="#onLeftParen" prefHeight="40" prefWidth="40.0" text="(" GridPane.columnIndex="1" />
                <Button onAction="#onDigit" prefHeight="40" prefWidth="40.0" text="3" GridPane.columnIndex="2" GridPane.rowIndex="3" />

            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="5" />
    </children>

</VBox>

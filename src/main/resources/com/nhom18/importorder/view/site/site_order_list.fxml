<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.nhom18.importorder.controller.site.SiteOrderListController"
      spacing="20" styleClass="content-panel">
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="📬 ĐƠN HÀNG NHẬN ĐƯỢC" styleClass="title-main" />
        </VBox>
        <Button text="🔄 Làm mới" onAction="#handleRefresh" styleClass="button-secondary" />
    </HBox>
    
    <!-- Table and Filter -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Lọc trạng thái:" styleClass="label-secondary" />
            <ComboBox fx:id="cbOrderStatusFilter" prefWidth="180" styleClass="text-input" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button fx:id="btnViewDetail" text="👁️ Xem Chi Tiết &amp; Phản Hồi" onAction="#handleViewDetail" styleClass="button" disable="true" />
        </HBox>
        
        <TableView fx:id="tblOrders" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colOrderId" text="Mã Đơn" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colReqId" text="Mã Phiếu Yêu Cầu" prefWidth="150" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colDeliveryMethod" text="Vận Chuyển" prefWidth="140" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colCreatedDate" text="Ngày Gửi" prefWidth="150" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colEstArrival" text="Hạn Giao Dự Kiến" prefWidth="160" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colStatus" text="Trạng Thái" prefWidth="140" style="-fx-alignment: CENTER;" />
            </columns>
            <placeholder>
                <Label text="Không tìm thấy đơn hàng nào được gửi tới Site của bạn." />
            </placeholder>
        </TableView>
    </VBox>
    
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.nhom18.importorder.controller.site.SiteOrderDetailController"
      spacing="20" styleClass="content-panel">
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="⬅️ Quay lại" onAction="#handleBack" styleClass="button-secondary" />
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTitle" text="📦 CHI TIẾT ĐƠN HÀNG NHẬN ĐƯỢC" styleClass="title-main" />
            <Label text="Xem thông tin chi tiết và đưa ra phản hồi phê duyệt/từ chối cung ứng." styleClass="title-sub" />
        </VBox>
    </HBox>
    
    <!-- Info Card -->
    <GridPane styleClass="card" hgap="30" vgap="15">
        <columnConstraints>
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="25" />
        </columnConstraints>
        
        <Label text="Mã Đơn Hàng:" styleClass="label-secondary" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <Label fx:id="lblOrderId" text="-" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Hình Thức Vận Chuyển:" styleClass="label-secondary" GridPane.columnIndex="2" GridPane.rowIndex="0" />
        <Label fx:id="lblDeliveryMethod" text="-" style="-fx-font-weight: bold;" GridPane.columnIndex="3" GridPane.rowIndex="0" />
        
        <Label text="Ngày Gửi Đơn:" styleClass="label-secondary" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <Label fx:id="lblCreatedDate" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <Label text="Hạn Giao Dự Kiến:" styleClass="label-secondary" GridPane.columnIndex="2" GridPane.rowIndex="1" />
        <Label fx:id="lblEstArrival" text="-" GridPane.columnIndex="3" GridPane.rowIndex="1" />
        
        <Label text="Trạng Thái:" styleClass="label-secondary" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <Label fx:id="lblStatus" text="-" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label fx:id="lblCancelReasonTitle" text="Lý do từ chối:" styleClass="label-secondary" visible="false" GridPane.columnIndex="2" GridPane.rowIndex="2" />
        <Label fx:id="lblCancelReason" text="-" style="-fx-text-fill: #ef4444;" visible="false" GridPane.columnIndex="3" GridPane.rowIndex="2" />
    </GridPane>
    
    <!-- Table Card -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15">
        <Label text="DANH SÁCH MẶT HÀNG YÊU CẦU" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
        
        <TableView fx:id="tblOrderItems" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colItemCode" text="Mã Mặt Hàng" prefWidth="150" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colItemName" text="Tên Mặt Hàng" prefWidth="350" />
                <TableColumn fx:id="colQtyOrdered" text="Số Lượng Yêu Cầu" prefWidth="180" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colUnit" text="Đơn Vị" prefWidth="120" style="-fx-alignment: CENTER;" />
            </columns>
        </TableView>
    </VBox>
    
    <!-- Actions Bar -->
    <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="card" style="-fx-padding: 15px;">
        <Label text="Hành động phản hồi đơn hàng:" styleClass="label-secondary" style="-fx-alignment: center;" />
        <Pane HBox.hgrow="ALWAYS" />
        <Button fx:id="btnReject" text="❌ Từ Chối Cung Cấp" onAction="#handleReject" styleClass="button" style="-fx-background-color: #ef4444;" />
        <Button fx:id="btnConfirm" text="✅ Xác Nhận Cung Cấp" onAction="#handleConfirm" styleClass="button" style="-fx-background-color: #3b82f6;" />
        <Button fx:id="btnShip" text="🚀 Đã Xuất Hàng Đi" onAction="#handleShip" styleClass="button" style="-fx-background-color: #06b6d4;" />
    </HBox>
    
</VBox>

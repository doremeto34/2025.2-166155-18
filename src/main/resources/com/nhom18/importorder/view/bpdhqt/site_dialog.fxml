<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.nhom18.importorder.controller.bpdhqt.SiteDialogController"
      spacing="20" style="-fx-padding: 25px; -fx-background-color: #f8fafc;" prefWidth="480.0">
    
    <!-- Title -->
    <VBox spacing="5">
        <Label fx:id="lblTitle" text="➕ THÊM MỚI ĐỐI TÁC SITE" style="-fx-font-size: 18px; -fx-font-weight: bold;" styleClass="label" />
        <Label text="Vui lòng điền đầy đủ và chính xác thông tin đối tác cung ứng." styleClass="title-sub" />
    </VBox>
    
    <Separator style="-fx-opacity: 0.2;" />
    
    <!-- Form Fields -->
    <GridPane hgap="15" vgap="15">
        <columnConstraints>
            <ColumnConstraints minWidth="150" prefWidth="160" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
        </columnConstraints>
        
        <children>
            <Label text="Mã đối tác (Site Code): *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtSiteCode" promptText="Ví dụ: TOKYO, SEOUL, ..." styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="Tên đối tác (Site Name): *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txtSiteName" promptText="Tên đầy đủ của Site nhập khẩu" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Ngày ship đường biển: *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="txtShipDays" promptText="Ví dụ: 15" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            
            <Label text="Ngày ship hàng không: *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="txtAirDays" promptText="Ví dụ: 3" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            
            <Label text="Thông tin liên hệ khác:" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.valignment="TOP" />
            <TextArea fx:id="txtOtherInfo" promptText="Địa chỉ, số điện thoại liên hệ, email, v.v." prefHeight="100.0" wrapText="true" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        </children>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>
    
    <Separator style="-fx-opacity: 0.2;" />
    
    <!-- Actions -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="❌ Hủy bỏ" onAction="#handleCancel" styleClass="button-secondary" />
        <Button text="💾 Lưu thông tin" onAction="#handleSave" styleClass="button" />
    </HBox>
    
</VBox>

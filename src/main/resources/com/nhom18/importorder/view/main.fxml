<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane fx:id="mainContainer" prefHeight="900.0" prefWidth="1500.0" styleClass="main-shell" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nhom18.importorder.controller.MainController">
   <top>
      <HBox spacing="15.0" styleClass="top-bar" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btnToggleSidebar" mnemonicParsing="false" onAction="#handleToggleSidebar" styleClass="button-toggle" text="☰ Menu" />
            <Label styleClass="top-bar-title" text="HỆ THỐNG ĐẶT HÀNG NHẬP KHẨU" />
         </children>
      </HBox>
   </top>
   <left>
      <fx:include fx:id="sidebar" source="sidebar.fxml" />
   </left>
   <center>
      <StackPane fx:id="contentArea" styleClass="content-panel" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>


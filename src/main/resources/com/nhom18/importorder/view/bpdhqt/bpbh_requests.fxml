<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="20.0" styleClass="content-panel" stylesheets="@../../../../../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nhom18.importorder.controller.bpdhqt.BpbhRequestListController">
   <children>
      <!-- Header -->
      <HBox alignment="CENTER_LEFT" spacing="20">
         <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="📋 ĐƠN YÊU CẦU TỪ BỘ PHẬN BÁN HÀNG" styleClass="title-main" />
         </VBox>
         <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="button-secondary" text="🔄 Làm Mới" />
      </HBox>

      <!-- SplitPane Layout for Master-Detail View -->
      <SplitPane dividerPositions="0.55" styleClass="split-pane-custom" VBox.vgrow="ALWAYS">
         <items>
            <!-- Left Panel: Master Request List -->
            <VBox spacing="12.0" styleClass="card-panel">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label styleClass="section-title" text="Danh Sách Phiếu Yêu Cầu" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="cbStatusFilter" prefWidth="220.0" promptText="Lọc theo trạng thái" styleClass="combo-box-filter" />
                     </children>
                  </HBox>
                  <TableView fx:id="tblRequests" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colId" maxWidth="80.0" minWidth="60.0" prefWidth="70.0" text="Mã YC" />
                        <TableColumn fx:id="colCreator" prefWidth="180.0" text="Nhân Viên Tạo" />
                        <TableColumn fx:id="colDate" prefWidth="140.0" text="Ngày Khởi Tạo" />
                        <TableColumn fx:id="colStatus" prefWidth="130.0" text="Trạng Thái" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </VBox>

            <!-- Right Panel: Detail Item List -->
            <VBox spacing="12.0" styleClass="card-panel" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px;">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Label styleClass="section-title" text="Chi Tiết Mặt Hàng Của Phiếu" HBox.hgrow="ALWAYS" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -accent-cyan;" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <HBox fx:id="hboxActions" spacing="8.0" visible="false" managed="false">
                           <children>
                              <Button fx:id="btnApprove" mnemonicParsing="false" onAction="#handleApprove" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✅ Duyệt" />
                              <Button fx:id="btnReject" mnemonicParsing="false" onAction="#handleReject" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="❌ Từ Chối" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
                  
                  <!-- Metadata display panel -->
                  <GridPane fx:id="gridRequestDetail" hgap="15" vgap="5" visible="false" managed="false" style="-fx-background-color: #f8fafc; -fx-padding: 10px; -fx-background-radius: 6px; -fx-border-color: #e2e8f0; -fx-border-width: 1px; -fx-border-radius: 6px;">
                     <columnConstraints>
                        <ColumnConstraints percentWidth="25" />
                        <ColumnConstraints percentWidth="75" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                     </rowConstraints>
                     <children>
                        <Label text="Mã phiếu:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: -text-secondary;" />
                        <Label fx:id="lblReqId" text="..." GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Người tạo &amp; Ngày:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: -text-secondary;" />
                        <Label fx:id="lblReqCreatorDate" text="..." GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     </children>
                  </GridPane>

                  <TableView fx:id="tblRequestItems" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colItemMerch" maxWidth="120.0" minWidth="90.0" prefWidth="100.0" text="Mã Hàng" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colItemName" prefWidth="200.0" text="Tên Mặt Hàng" />
                        <TableColumn fx:id="colItemQty" maxWidth="100.0" minWidth="70.0" prefWidth="80.0" text="Số Lượng" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colItemUnit" maxWidth="80.0" minWidth="60.0" prefWidth="70.0" text="Đơn Vị" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colItemDate" prefWidth="140.0" text="Ngày Nhận Mong Muốn" style="-fx-alignment: CENTER;" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                     <placeholder>
                        <Label text="Chọn một phiếu yêu cầu bên trái để xem chi tiết mặt hàng." style="-fx-text-fill: -text-secondary; -fx-font-style: italic;" />
                     </placeholder>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </children>
</VBox>

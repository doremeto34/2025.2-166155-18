<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.nhom18.importorder.controller.bpbh.CreateRequestController"
      spacing="20" styleClass="content-panel">
    
    <VBox spacing="5">
        <Label text="➕ TẠO YÊU CẦU NHẬP HÀNG MỚI" styleClass="title-main" />
    </VBox>
    
    <SplitPane dividerPositions="0.45" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0;">
        <items>
            <!-- BÊN TRÁI: CATALOG & BỘ LỌC CHỌN SẢN PHẨM -->
            <VBox spacing="15" styleClass="card" style="-fx-background-radius: 12px 0 0 12px; -fx-border-radius: 12px 0 0 12px;">
                <Label text="1. Chọn sản phẩm từ Catalog" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -accent-cyan;" />
                
                <TextField fx:id="txtSearchProduct" promptText="🔍 Gõ mã sản phẩm hoặc tên sản phẩm..." />
                
                <TableView fx:id="tblProductCatalog" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCatalogCode" text="Mã Sản Phẩm" prefWidth="120" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colCatalogName" text="Tên Sản Phẩm" prefWidth="200" />
                        <TableColumn fx:id="colCatalogUnit" text="Đơn Vị" prefWidth="80" style="-fx-alignment: CENTER;" />
                    </columns>
                </TableView>
                
                <Separator style="-fx-opacity: 0.1;" />
                
                <GridPane hgap="15" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="35" />
                        <ColumnConstraints percentWidth="65" />
                    </columnConstraints>
                    
                    <Label text="Số lượng cần đặt:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtQuantity" promptText="Ví dụ: 10" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    
                    <Label text="Ngày nhận mong muốn:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                    <DatePicker fx:id="dpDesiredDate" promptText="Chọn ngày trong tương lai" GridPane.columnIndex="1" GridPane.rowIndex="1" HBox.hgrow="ALWAYS" style="-fx-width: 100%;" />
                </GridPane>
                
                <Button text="➕ Thêm vào phiếu yêu cầu" fx:id="btnAddItem" onAction="#handleAddItemToCart" styleClass="button" style="-fx-alignment: CENTER;" maxWidth="Infinity" />
            </VBox>
            
            <!-- BÊN PHẢI: BẢNG DANH SÁCH HÀNG ĐÃ THÊM (GIỎ HÀNG) -->
            <VBox spacing="15" styleClass="card" style="-fx-background-radius: 0 12px 12px 0; -fx-border-radius: 0 12px 12px 0; -fx-border-width: 1px 1px 1px 0;">
                <HBox alignment="CENTER_LEFT">
                    <Label text="2. Danh sách mặt hàng yêu cầu nhập" HBox.hgrow="ALWAYS" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -accent-indigo;" />
                    <Pane HBox.hgrow="ALWAYS" />
                    <Button text="🗑 Xoá sạch" onAction="#handleClearCart" styleClass="button-secondary" style="-fx-padding: 5px 12px; -fx-font-size: 12px;" />
                </HBox>
                
                <TableView fx:id="tblCartItems" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCartCode" text="Mã Hàng" prefWidth="120" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colCartName" text="Tên Mặt Hàng" prefWidth="220" />
                        <TableColumn fx:id="colCartQty" text="Số Lượng" prefWidth="100" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colCartUnit" text="Đơn Vị" prefWidth="90" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colCartDate" text="Ngày Mong Muốn" prefWidth="140" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colCartAction" text="Xóa" prefWidth="80" style="-fx-alignment: CENTER;" />
                    </columns>
                    <placeholder>
                        <Label text="Chưa có mặt hàng nào được thêm vào yêu cầu." />
                    </placeholder>
                </TableView>
                
                <HBox alignment="CENTER_RIGHT" spacing="20">
                    <Button text="❌ Hủy Bỏ" onAction="#handleCancel" styleClass="button-secondary" />
                    <Button text="🚀 Gửi Yêu Cầu Nhập Hàng" fx:id="btnSubmit" onAction="#handleSubmitRequest" styleClass="button" style="-fx-background-color: -accent-indigo;" />
                </HBox>
            </VBox>
        </items>
    </SplitPane>
    
</VBox>

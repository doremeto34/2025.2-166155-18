<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.nhom18.importorder.controller.admin.ChangePasswordDialogController"
      spacing="20" style="-fx-padding: 25px; -fx-background-color: #f8fafc;" prefWidth="420.0">
    
    <!-- Title -->
    <VBox spacing="5">
        <Label text="🔑 ĐẶT LẠI MẬT KHẨU" style="-fx-font-size: 18px; -fx-font-weight: bold;" styleClass="label" />
        <Label text="Cấp lại mật khẩu mới cho tài khoản nhân viên." styleClass="title-sub" />
    </VBox>
    
    <Separator style="-fx-opacity: 0.2;" />
    
    <!-- Form Fields -->
    <GridPane hgap="12" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="130" prefWidth="140" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
        </columnConstraints>
        
        <children>
            <Label text="Tên tài khoản:" styleClass="label-secondary" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="lblUsername" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="Mật khẩu mới: *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <PasswordField fx:id="txtNewPassword" promptText="Nhập mật khẩu mới..." styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Xác nhận lại: *" styleClass="label-secondary" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <PasswordField fx:id="txtConfirmPassword" promptText="Nhập lại mật khẩu mới..." styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        </children>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>
    
    <Separator style="-fx-opacity: 0.2;" />
    
    <!-- Actions -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="❌ Hủy bỏ" onAction="#handleCancel" styleClass="button-secondary" />
        <Button text="💾 Cập nhật" onAction="#handleSave" styleClass="button" />
    </HBox>
    
</VBox>

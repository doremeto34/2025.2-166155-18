<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.nhom18.importorder.controller.bpdhqt.RequestProcessingController"
      spacing="20" styleClass="content-panel">
    
    <!-- Header -->
    <VBox spacing="5">
        <Label text="⚡ PHÂN BỔ SITE TỰ ĐỘNG &amp; TẠO ĐƠN" styleClass="title-main" />
        <Label text="Xử lý các phiếu yêu cầu PENDING bằng thuật toán phân bổ tối ưu SHIP/AIR để lập đơn đặt hàng." styleClass="title-sub" />
    </VBox>
    
    <!-- Main Workspace TabPane -->
    <TabPane fx:id="tabPaneRequest" VBox.vgrow="ALWAYS" styleClass="tab-pane" style="-fx-background-color: transparent;">
        <tabs>
            <Tab fx:id="tabSelect" text="📋 Bước 1: Chọn Yêu Cầu &amp; Mặt Hàng" closable="false">
                <content>
                    <VBox spacing="15" style="-fx-padding: 15px 0 0 0;">
                        <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="12">
                            <Label text="1. Chọn Yêu Cầu Chờ Xử Lý" style="-fx-font-size: 16px; -fx-font-weight: bold;" styleClass="label" />
                            
                            <TableView fx:id="tblPendingRequests" prefHeight="250" minHeight="180">
                                <columns>
                                    <TableColumn fx:id="colReqId" text="Mã Phiếu" prefWidth="120" style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colReqCreator" text="Người Tạo" prefWidth="250" />
                                    <TableColumn fx:id="colReqDate" text="Ngày Tạo" prefWidth="200" style="-fx-alignment: CENTER;" />
                                </columns>
                                <placeholder>
                                    <Label text="Không có yêu cầu nào chờ xử lý." />
                                </placeholder>
                            </TableView>
                            
                            <Separator style="-fx-opacity: 0.2;" />
                            
                            <Label text="Danh Sách Mặt Hàng Trong Phiếu" style="-fx-font-size: 14px; -fx-font-weight: bold;" styleClass="label-secondary" />
                            
                            <TableView fx:id="tblRequestItems" VBox.vgrow="ALWAYS" prefHeight="280">
                                <columns>
                                    <TableColumn fx:id="colItemMerch" text="Mã Hàng" prefWidth="150" />
                                    <TableColumn fx:id="colItemName" text="Tên Mặt Hàng" prefWidth="350" />
                                    <TableColumn fx:id="colItemQty" text="SL Đặt" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;" />
                                    <TableColumn fx:id="colItemUnit" text="ĐVT" prefWidth="100" style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colItemDate" text="Ngày Mong Muốn" prefWidth="200" style="-fx-alignment: CENTER;" />
                                </columns>
                                <placeholder>
                                    <Label text="Hãy chọn một phiếu yêu cầu ở bảng trên để xem chi tiết." />
                                </placeholder>
                            </TableView>
                            
                            <HBox alignment="CENTER" spacing="10">
                                <Button fx:id="btnRunAllocation" text="⚙️ Chạy Phân Bổ Tự Động &amp; Xem Đề Xuất" onAction="#handleRunAllocation" styleClass="button" prefWidth="400" />
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </Tab>
            
            <Tab fx:id="tabProposed" text="⚡ Bước 2: Kết Quả Phân Bổ Đề Xuất" closable="false">
                <content>
                    <VBox spacing="15" style="-fx-padding: 15px 0 0 0;">
                        <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15">
                            <Label text="2. Kết Quả Phân Bổ Đề Xuất" style="-fx-font-size: 16px; -fx-font-weight: bold;" styleClass="label" />
                            
                            <TableView fx:id="tblAllocationProposed" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colPropMerch" text="Mã Hàng" prefWidth="120" />
                                    <TableColumn fx:id="colPropName" text="Tên Mặt Hàng" prefWidth="350" />
                                    <TableColumn fx:id="colPropSite" text="Site Phân Bổ" prefWidth="300" />
                                    <TableColumn fx:id="colPropMethod" text="Phương Thức" prefWidth="150" style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colPropQty" text="SL Lấy" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;" />
                                    <TableColumn fx:id="colPropArrival" text="Ngày Giao Dự Kiến" prefWidth="200" style="-fx-alignment: CENTER;" />
                                </columns>
                                <placeholder>
                                    <Label fx:id="lblProposedPlaceholder" text="Chưa có dữ liệu phân bổ. Vui lòng chọn yêu cầu ở Bước 1 và bấm 'Chạy Phân Bổ Tự Động'." />
                                </placeholder>
                            </TableView>
                            
                            <!-- Error / Status Notice Area -->
                            <VBox fx:id="boxError" spacing="5" visible="false" managed="false" style="-fx-background-color: rgba(239, 68, 68, 0.1); -fx-border-color: #ef4444; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 15;">
                                <Label fx:id="lblAllocationError" text="Lỗi phân bổ..." textFill="#dc2626" wrapText="true" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                            </VBox>
                            
                            <HBox alignment="CENTER_RIGHT" spacing="12">
                                <Button fx:id="btnCancelProposed" text="⬅️ Quay Lại &amp; Hủy Đề Xuất" onAction="#handleCancelProposed" styleClass="button-secondary" />
                                <Button fx:id="btnApproveOrders" text="✅ Duyệt &amp; Tạo Đơn Hàng" onAction="#handleApproveOrders" styleClass="button" />
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </Tab>
        </tabs>
    </TabPane>
    
</VBox>

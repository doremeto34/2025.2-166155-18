<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.nhom18.importorder.controller.bpdhqt.OrderListController"
      spacing="20" styleClass="content-panel" stylesheets="@../../../../../css/styles.css">
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="📦 DANH SÁCH ĐƠN HÀNG NHẬP KHẨU" styleClass="title-main" />
        </VBox>
        <Button fx:id="btnReallocate" text="⚡ Tái phân bổ đơn" onAction="#handleReallocate" styleClass="button-primary" style="-fx-background-color: #fb923c;" disable="true" />
        <Button text="🔄 Làm mới" onAction="#handleRefresh" styleClass="button-secondary" />
    </HBox>
    
    <!-- SplitPane Layout for Master-Detail View -->
    <SplitPane dividerPositions="0.52" styleClass="split-pane-custom" VBox.vgrow="ALWAYS">
        <items>
            <!-- Left Panel: Master Order List -->
            <VBox spacing="15.0" styleClass="card-panel" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px;">
                <children>
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="Lọc trạng thái:" styleClass="label-secondary" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="cbOrderStatusFilter" prefWidth="180" styleClass="text-input" />
                    </HBox>
                    
                    <TableView fx:id="tblOrders" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colOrderId" text="Mã Đơn" maxWidth="70" minWidth="50" prefWidth="60" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colSiteName" text="Site Nhập Khẩu" prefWidth="140" />
                            <TableColumn fx:id="colDeliveryMethod" text="Vận Chuyển" maxWidth="90" minWidth="70" prefWidth="80" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colCreatedDate" text="Ngày Tạo" maxWidth="100" minWidth="80" prefWidth="90" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colEstArrival" text="Ngày Về Dự Kiến" maxWidth="110" minWidth="90" prefWidth="100" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colStatus" text="Trạng Thái" maxWidth="100" minWidth="80" prefWidth="90" style="-fx-alignment: CENTER;" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <placeholder>
                            <Label text="Không có đơn đặt hàng nhập khẩu nào được tạo." />
                        </placeholder>
                    </TableView>
                </children>
            </VBox>

            <!-- Right Panel: Detail Order Items List -->
            <VBox spacing="15.0" styleClass="card-panel" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px;">
                <children>
                    <Label styleClass="section-title" text="Chi Tiết Mặt Hàng Của Đơn" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -accent-cyan;" />
                    <TableView fx:id="tblOrderItems" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colItemCode" maxWidth="100.0" minWidth="70.0" prefWidth="80.0" text="Mã SP" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colItemName" prefWidth="180.0" text="Tên Sản Phẩm" />
                            <TableColumn fx:id="colItemQtyOrdered" maxWidth="90.0" minWidth="65.0" prefWidth="75.0" text="SL Đặt" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colItemQtyConfirmed" maxWidth="95.0" minWidth="70.0" prefWidth="80.0" text="SL Site Giao" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colItemQtyReceived" maxWidth="95.0" minWidth="70.0" prefWidth="80.0" text="SL Thực Nhận" style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colItemUnit" maxWidth="80.0" minWidth="50.0" prefWidth="60.0" text="Đơn Vị" style="-fx-alignment: CENTER;" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <placeholder>
                            <Label text="Chọn một đơn hàng bên trái để xem chi tiết mặt hàng." style="-fx-text-fill: -text-secondary; -fx-font-style: italic;" />
                        </placeholder>
                    </TableView>
                </children>
            </VBox>
        </items>
    </SplitPane>
    
</VBox>
